{
  "manifest_version": 3,
  "name": "OpenClaw Relay Next",
  "version": "0.1.0",
  "description": "Resilient browser relay for OpenClaw",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Bind this tab to OpenClaw Relay"
  },
  "options_ui": {
    "page": "src/diagnostics.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/main.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/main.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "relay-next@openclaw.local"
    }
  }
}
