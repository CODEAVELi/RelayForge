{
  "manifest_version": 3,
  "name": "RelayForge",
  "version": "0.1.1",
  "description": "Resilient browser relay for OpenClaw",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Bind this tab to RelayForge"
  },
  "options_page": "src/diagnostics.html",
  "background": {
    "service_worker": "src/background/main.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/main.js"],
      "run_at": "document_idle"
    }
  ]
}
